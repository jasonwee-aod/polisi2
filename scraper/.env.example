# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=replace-with-service-role

# DigitalOcean Spaces
DO_SPACES_KEY=replace-with-access-key
DO_SPACES_SECRET=replace-with-secret-key
DO_SPACES_BUCKET=your-space-name
DO_SPACES_REGION=sgp1
DO_SPACES_ENDPOINT=https://sgp1.digitaloceanspaces.com

# Scraper runtime
SCRAPER_USER_AGENT=PolisiScraper/1.0 (+https://polisigpt.local)
SCRAPER_TIMEOUT_SECONDS=30
SCRAPER_MAX_RETRIES=3
SCRAPER_RETRY_BACKOFF_SECONDS=1.5
SCRAPER_STATE_DB_PATH=.cache/scraper_state.sqlite3
SCRAPER_TEMP_DIR=.cache/tmp
SCRAPER_POLITENESS_DELAY_SECONDS=0.5

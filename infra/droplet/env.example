# =============================================================================
# Polisi GPT — Droplet .env (placed at /opt/polisigpt/.env)
# Shared by API, scraper, and indexer services
# =============================================================================

# --- API ---
API_ENV=production
API_HOST=0.0.0.0
API_PORT=8000
API_ALLOWED_ORIGINS=https://your-frontend-domain.vercel.app

# --- Supabase ---
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_DB_URL=postgresql://postgres:password@db.your-project.supabase.co:5432/postgres
SUPABASE_JWT_SECRET=replace-with-jwt-secret
SUPABASE_SERVICE_ROLE_KEY=replace-with-service-role

# --- LLM / Embeddings ---
ANTHROPIC_API_KEY=replace-with-anthropic-key
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022
OPENAI_API_KEY=replace-with-openai-key

# --- DigitalOcean Spaces ---
DO_SPACES_KEY=replace-with-access-key
DO_SPACES_SECRET=replace-with-secret-key
DO_SPACES_BUCKET=polisi-gov-docs
DO_SPACES_REGION=sgp1
DO_SPACES_ENDPOINT=https://sgp1.digitaloceanspaces.com

# --- Retrieval tuning ---
RETRIEVAL_LIMIT=5
RETRIEVAL_MIN_SIMILARITY=0.45
RETRIEVAL_WEAK_SIMILARITY=0.65

# --- Scraper runtime ---
SCRAPER_USER_AGENT=PolisiScraper/1.0 (+https://polisigpt.local)
SCRAPER_TIMEOUT_SECONDS=30
SCRAPER_MAX_RETRIES=3
SCRAPER_RETRY_BACKOFF_SECONDS=1.5
SCRAPER_STATE_DB_PATH=.cache/scraper_state.sqlite3
SCRAPER_TEMP_DIR=.cache/tmp
SCRAPER_POLITENESS_DELAY_SECONDS=0.5

# --- Indexer runtime ---
INDEXER_SPACES_PREFIX=gov-my/
INDEXER_BATCH_SIZE=16
INDEXER_MAX_ITEMS_PER_RUN=0
INDEXER_CHUNK_SIZE=1400
INDEXER_CHUNK_OVERLAP=250
INDEXER_SIMILARITY_LIMIT=5

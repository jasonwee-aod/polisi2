                              "fontWeight": "700",
                              "letterSpacing": 1
                            },
                            {
                              "type": "text",
                              "id": "81kJk",
                              "name": "docChapterSubtitle",
                              "fill": "$text-primary",
                              "textGrowth": "fixed-width",
                              "width": "fill_container",
                              "content": "TRANSFER OF PERSONAL DATA",
                              "textAlign": "center",
                              "fontFamily": "Outfit",
                              "fontSize": 11,
                              "fontWeight": "600",
                              "letterSpacing": 0.5
                            },
                            {
                              "type": "text",
                              "id": "leddT",
                              "name": "docArticle",
                              "fill": "$text-primary",
                              "textGrowth": "fixed-width",
                              "width": "fill_container",
                              "content": "Article 56",
                              "fontFamily": "Outfit",
                              "fontSize": 12,
                              "fontWeight": "700"
                            },
                            {
                              "type": "text",
                              "id": "nDL7u",
                              "name": "docPara1",
                              "fill": "$text-secondary",
                              "textGrowth": "fixed-width",
                              "width": "fill_container",
                              "content": "(1) Transfer of Personal Data to other countries shall be conducted by Personal Data Controllers and/or Personal Data Processors in accordance with the provisions of this Law.",
                              "lineHeight": 1.6,
                              "fontFamily": "Outfit",
                              "fontSize": 12,
                              "fontWeight": "normal"
                            },
                            {
                              "type": "text",
                              "id": "wrk9D",
                              "name": "docPara2",
                              "fill": "$text-secondary",
                              "textGrowth": "fixed-width",
                              "width": "fill_container",
                              "content": "(2) Transfer of Personal Data to other countries by Personal Data Controllers and/or Personal Data Processors may be conducted upon verification by the minister regarding:",
                              "lineHeight": 1.6,
                              "fontFamily": "Outfit",
                              "fontSize": 12,
                              "fontWeight": "normal"
                            },
                            {
                              "type": "frame",
                              "id": "tzAXb",
                              "name": "Highlighted Paragraph",
                              "width": "fill_container",
                              "fill": "#E8F5ED",
                              "cornerRadius": 6,
                              "gap": 8,
                              "padding": [
                                8,
                                10
                              ],
                              "children": [
                                {
                                  "type": "rectangle",
                                  "cornerRadius": 2,
                                  "id": "K1Dsf",
                                  "name": "hBar",
                                  "fill": "#3D8A5A",
                                  "width": 3,
                                  "height": "fill_container"
                                },
                                {
                                  "type": "text",
                                  "id": "zkPZB",
                                  "name": "hText",
                                  "fill": "$text-primary",
                                  "textGrowth": "fixed-width",
                                  "width": "fill_container",
                                  "content": "(3) Transfer of personal data outside the federation of Malaysia may be carried out if the receiving country has an adequate level of personal data protection, or if adequate safeguards are provided.",
                                  "lineHeight": 1.6,
                                  "fontFamily": "Outfit",
                                  "fontSize": 12,
                                  "fontWeight": "normal"
                                }
                              ]
                            },
                            {
                              "type": "text",
                              "id": "hobJB",
                              "name": "docPara4",
                              "fill": "$text-secondary",
                              "textGrowth": "fixed-width",
                              "width": "fill_container",
                              "content": "(4) In the event that the conditions as referred to in paragraph (3) are not fulfilled, the transfer of Personal Data abroad may be carried out with the consent of the Personal Data Subject.",
                              "lineHeight": 1.6,
                              "fontFamily": "Outfit",
                              "fontSize": 12,
                              "fontWeight": "normal"
                            },
                            {
                              "type": "text",
                              "id": "eGXgq",
                              "name": "docPara5",
                              "fill": "$text-secondary",
                              "textGrowth": "fixed-width",
                              "width": "fill_container",
                              "content": "(5) Further provisions regarding the transfer of Personal Data abroad shall be regulated by Government Regulation.",
                              "lineHeight": 1.6,
                              "fontFamily": "Outfit",
                              "fontSize": 12,
                              "fontWeight": "normal"
                            }
                          ]
                        }
                      ]
                    }
                  ]
                }
              ]
            }
          ]
        }
      ]
    }

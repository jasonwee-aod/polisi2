                                  "fill": "$text-primary",
                                  "textGrowth": "fixed-width",
                                  "width": 460,
                                  "content": "What are the key requirements for data privacy compliance under Malaysian law?",
                                  "lineHeight": 1.5,
                                  "fontFamily": "Outfit",
                                  "fontSize": 15,
                                  "fontWeight": "normal"
                                }
                              ]
                            },
                            {
                              "type": "frame",
                              "id": "3foLK",
                              "name": "User Avatar",
                              "width": 28,
                              "height": 28,
                              "fill": "#3D8A5A",
                              "cornerRadius": 100,
                              "justifyContent": "center",
                              "alignItems": "center",
                              "children": [
                                {
                                  "type": "text",
                                  "id": "Mfuzz",
                                  "name": "userInitials",
                                  "fill": "#FFFFFF",
                                  "content": "JW",
                                  "fontFamily": "Outfit",
                                  "fontSize": 10,
                                  "fontWeight": "600"
                                }
                              ]
                            }
                          ]
                        },
                        {
                          "type": "frame",
                          "id": "QKe8m",
                          "name": "AI Response",
                          "width": "fill_container",
                          "gap": 12,
                          "children": [
                            {
                              "type": "frame",
                              "id": "NLpMQ",
                              "name": "AI Avatar",
                              "width": 28,
                              "height": 28,
                              "fill": "$text-primary",
                              "cornerRadius": 100,
                              "justifyContent": "center",
                              "alignItems": "center",
                              "children": [
                                {
                                  "type": "text",
                                  "id": "VgGhz",
                                  "name": "aiInitials",
                                  "fill": "#FFFFFF",
                                  "content": "P",
                                  "fontFamily": "Outfit",
                                  "fontSize": 13,
                                  "fontWeight": "700"
                                }
                              ]
                            },
                            {
                              "type": "frame",
                              "id": "8lR2Q",
                              "name": "AI Content",
                              "width": "fill_container",
                              "layout": "vertical",
                              "gap": 16,
                              "children": [
                                {
                                  "type": "text",
                                  "id": "IbcFE",
                                  "name": "aiPara1",
                                  "fill": "$text-primary",
                                  "textGrowth": "fixed-width",
                                  "width": "fill_container",
                                  "content": "Malaysia's data privacy framework is primarily governed by Law No. 27 of 2022 on Personal Data Protection (PDP Law), which came into effect in October 2022. Here are the key compliance requirements:",
                                  "lineHeight": 1.7,
                                  "fontFamily": "Outfit",
                                  "fontSize": 15,
                                  "fontWeight": "normal"
                                },
                                {
                                  "type": "text",
                                  "id": "YqdBy",
                                  "name": "heading1",
                                  "fill": "$text-primary",
                                  "content": "1. Lawful Basis for Processing",
                                  "fontFamily": "Outfit",
                                  "fontSize": 15,
                                  "fontWeight": "600"
                                },
                                {
                                  "type": "text",
                                  "id": "kbu4V",
                                  "name": "aiPara2",
                                  "fill": "$text-primary",
                                  "textGrowth": "fixed-width",
                                  "width": "fill_container",
                                  "content": "Organizations must establish a valid legal basis before processing personal data. This includes obtaining explicit consent from data subjects, fulfilling contractual obligations, or complying with legal requirements.",
                                  "lineHeight": 1.7,
                                  "fontFamily": "Outfit",
                                  "fontSize": 15,
                                  "fontWeight": "normal"
                                },
                                {
                                  "type": "text",
                                  "id": "FfMKv",
                                  "name": "heading2",
                                  "fill": "$text-primary",
                                  "content": "2. Data Subject Rights",
                                  "fontFamily": "Outfit",
                                  "fontSize": 15,
                                  "fontWeight": "600"
                                },
                                {
                                  "type": "text",
                                  "id": "rksIG",
                                  "name": "aiPara3",
                                  "fill": "$text-primary",
                                  "textGrowth": "fixed-width",
                                  "width": "fill_container",
                                  "content": "The PDP Law grants individuals several rights including the right to access, correct, delete, and restrict processing of their personal data. Organizations must establish mechanisms to facilitate these rights.",
                                  "lineHeight": 1.7,
                                  "fontFamily": "Outfit",
                                  "fontSize": 15,
                                  "fontWeight": "normal"
                                },
                                {
                                  "type": "text",
                                  "id": "HW9qK",
                                  "name": "heading3",
                                  "fill": "$text-primary",
                                  "content": "3. Cross-Border Data Transfer",
                                  "fontFamily": "Outfit",
                                  "fontSize": 15,
                                  "fontWeight": "600"
                                },
                                {
                                  "type": "frame",
                                  "id": "ylbFG",
                                  "name": "Citation Paragraph",
                                  "width": "fill_container",
                                  "alignItems": "end",
                                  "children": [
                                    {
                                      "type": "text",
                                      "id": "Rgjt9",
                                      "name": "citationText",
                                      "fill": "$text-primary",
                                      "textGrowth": "fixed-width",
                                      "width": "fill_container",
                                      "content": "Transfer of personal data outside Indonesia is permitted only if the receiving country provides an equivalent level of data protection, or if adequate safeguards are in place.",
                                      "lineHeight": 1.7,
                                      "fontFamily": "Outfit",
                                      "fontSize": 15,
                                      "fontWeight": "normal"
                                    }
                                  ]
                                },
                                {
                                  "type": "text",
                                  "id": "grcWu",
                                  "fill": "#ba1b1bff",
                                  "content": "[PDF Law No. 27/2022]",
                                  "fontFamily": "$--font-secondary",
                                  "fontSize": 11,
                                  "fontWeight": "600"
                                },
                                {
                                  "type": "line",
                                  "id": "UDe3g",

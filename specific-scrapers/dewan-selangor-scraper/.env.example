# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# Path to your Google Cloud service account JSON key file.
GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json

# GCS bucket name where raw documents will be archived.
GCS_BUCKET=my-gov-rag-bucket

# Optional overrides (these match CLI defaults – only set if you need to change them):
# DEWAN_SELANGOR_DB_PATH=data/state.db
# DEWAN_SELANGOR_MANIFEST_DIR=data/manifests/dewan-selangor

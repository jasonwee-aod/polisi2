# ── Required for live GCS uploads ─────────────────────────────────────────────
# Path to a GCP service account JSON key with roles/storage.objectAdmin
# on the target bucket.
GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json

# Name of the GCS bucket where raw files are stored.
GCS_BUCKET=my-gov-rag-bucket

# ── Optional overrides ─────────────────────────────────────────────────────────
# Path to the SQLite state database (default: data/state.db)
# KPKT_DB_PATH=data/state.db

# Directory for records.jsonl and crawl_runs.jsonl (default: data/manifests/kpkt)
# KPKT_MANIFEST_DIR=data/manifests/kpkt

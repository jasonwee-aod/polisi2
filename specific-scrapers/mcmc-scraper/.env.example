# DigitalOcean Spaces credentials (S3-compatible)
DO_SPACES_KEY=your-access-key-here
DO_SPACES_SECRET=your-secret-key-here
DO_SPACES_BUCKET=your-space-name
DO_SPACES_REGION=sgp1
DO_SPACES_ENDPOINT=https://sgp1.digitaloceanspaces.com

# Optional overrides
MCMC_DB_PATH=data/state.db
MCMC_MANIFEST_DIR=data/manifests/mcmc

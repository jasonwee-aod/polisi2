# MOHE Scraper Configuration
# Copy to .env and fill in values (do not commit .env to version control)

# Google Cloud Storage (optional - if not set, files save to local disk)
GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account-key.json
GCS_BUCKET=my-gov-rag-bin

# Scraper runtime settings
MAX_PAGES=1000
CRAWL_TIMEOUT_SECONDS=300
RETRY_MAX_ATTEMPTS=3

# Data directory for local storage
DATA_DIR=./data
STATE_DB_PATH=./data/mohe_state.db

# Logging
LOG_LEVEL=INFO
